generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String   @id @default(uuid())
  email              String   @unique
  username           String   @unique
  password           String
  profileColor       String   @default("green")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  organizations      Organization[]
  projects           Project[]
  orgMemberShips     OrganizationMember[]
  projectMemberShips ProjectMember[]
  sentInvites        Invitation[] @relation("sentInvites")
  receivedInvites    Invitation[] @relation("receivedInvites")
  messages           Message[]
  settings           UserSettings?
  reminders          CalendarReminder[]
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])   
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  projects    Project[]
  members     OrganizationMember[]
  invitations Invitation[]
}

model Project {
  id             String       @id @default(uuid())
  name           String
  ownerId        String
  owner          User         @relation(fields: [ownerId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  members        ProjectMember[]
  messages       Message[]
  taskTables         TaskTable[]
}

model OrganizationMember {
  id             String       @id @default(uuid())
  role           String       @default("member")
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())

  @@unique([userId, organizationId])
}

model ProjectMember {
  id        String   @id @default(uuid())
  role      String   @default("member")
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, projectId])
}

model Invitation {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  invitedById    String
  invitedBy      User         @relation("sentInvites", fields: [invitedById], references: [id])
  invitedUserId  String
  invitedUser    User         @relation("receivedInvites", fields: [invitedUserId], references: [id])
  createdAt      DateTime     @default(now())
  expiresAt      DateTime?    // optional expiry
}

model Message {
  id          String    @id @default(uuid())
  message     String
  projectId   String
  project     Project   @relation(fields:[projectId], references: [id])
  userId      String
  user        User      @relation(fields:[userId], references: [id])
  createdAt   DateTime  @default(now())
}

model UserSettings {
  id          String    @id @default(uuid())
  userId      String    @unique
  user        User      @relation(fields:[userId], references: [id])
  invites     Boolean   @default(true)
}

model CalendarReminder {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields:[userId], references: [id])
  reminder    String
  date        DateTime
  time        String?
  duration    Int?
  color       String?
  createdAt   DateTime  @default(now())  
}

model TaskTable {
  id        String       @id @default(uuid())
  name      String
  order     Int
  projectId String
  project   Project      @relation(fields:[projectId], references: [id])
  cards     TaskCard[]
  createdAt DateTime     @default(now())
}

model TaskCard {
  id          String      @id @default(uuid())
  title       String
  description String?
  order       Int
  tableId     String
  table       TaskTable @relation(fields:[tableId], references: [id])
  createdAt   DateTime    @default(now())
}